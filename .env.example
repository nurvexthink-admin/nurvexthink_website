# Public (safe to expose; RLS protects data)
NEXT_PUBLIC_SUPABASE_URL=https://axbsghyqhhdaiylcksbv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side ONLY — never expose to the browser, never commit a real value
SUPABASE_SERVICE_ROLE_KEY=

# Secret admin-login path segment. The login page lives at /<ADMIN_SLUG>.
# Server-only (NOT NEXT_PUBLIC) so it never ships to the browser or the repo.
# Must be set in Vercel and in local .env.local, or the admin login 404s.
ADMIN_SLUG=

# Cloudflare Turnstile — bot check on the public order form.
# Site key is public (safe in the browser); secret key is server-only.
# For local dev use Cloudflare's always-pass TEST keys:
#   NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
#   TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# AI chatbot (docs/CHATBOT.md). Server-side ONLY — the /api/chat route reads it.
# NEVER rename this to NEXT_PUBLIC_*: that prefix is what ships a value to the
# browser, and it would publish your key to every visitor.
# Set a hard monthly spend limit in the OpenAI dashboard — it is the real cost cap.
# The chatbot stays hidden until it is switched on in /admin/chatbot.
OPENAI_API_KEY=

# Transactional email via ZeptoMail (docs/EMAIL.md). Server-side only.
# ZEPTOMAIL_SMTP_PASS is the Send-Mail token from the ZeptoMail agent's SMTP/API tab.
# If any of PASS / FROM / TO is missing, email is silently skipped (order still saves).
ZEPTOMAIL_SMTP_HOST=smtp.zeptomail.com
ZEPTOMAIL_SMTP_PORT=465
ZEPTOMAIL_SMTP_USER=emailapikey
ZEPTOMAIL_SMTP_PASS=
EMAIL_FROM=NurvexThink <nth@nurvexthink.com>
EMAIL_TO=nth@nurvexthink.com
EMAIL_REPLY_TO=nth@nurvexthink.com
